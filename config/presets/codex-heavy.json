{
  "_description": "Maximize ChatGPT Pro / Codex usage. Codex handles all audit + build work. Use when ChatGPT Pro quota is fresh.",
  "_mode": "codex-heavy",
  "_tier_semantics": {
    "editor": "code-generation-focused model for actual file edits, when primary is better at reasoning than writing code. Falls back to primary if unset.",
    "primary": "role-default agent from routing.phases/routing.roles",
    "weak": "cheap model for mechanical work: commit messages, diff summaries, lint-error interpretation, rubric-scoring. Cost target: 10-30% of primary."
  },
  "overrides": {},
  "providers": {
    "codex": {
      "default": "gpt-5.4",
      "fallback": "gpt-5.4-mini",
      "image": "gpt-image-1",
      "large_context": "gpt-5.4",
      "mini": "gpt-5.4-mini",
      "reasoning": "o3",
      "spark": "gpt-5.4"
    },
    "gemini": {
      "default": "gemini-2.5-flash",
      "fallback": "gemini-2.5-flash",
      "flash": "gemini-2.5-flash",
      "image": "gemini-3-pro-image-preview"
    }
  },
  "routing": {
    "phases": {
      "define": "codex:default",
      "deliver": "codex:default",
      "develop": "codex:default",
      "discover": "gemini:default",
      "research": "gemini:default",
      "review": "codex:default",
      "security": "codex:reasoning"
    },
    "roles": {
      "builder": "codex:default",
      "counter-audit": "claude",
      "editor": "codex:default",
      "image": "gemini:image",
      "researcher": "gemini:default",
      "weak": "codex:mini"
    }
  },
  "tiers": {
    "budget": {
      "codex": "mini",
      "gemini": "flash"
    },
    "premium": {
      "codex": "default",
      "gemini": "default"
    },
    "standard": {
      "codex": "default",
      "gemini": "default"
    }
  },
  "version": "3.0"
}
