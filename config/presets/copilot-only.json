{
  "_description": "Route everything through Copilot's multi-backend (claude/gpt-5/gemini internally). Use when direct account quotas are low. Preserves ChatGPT Pro + Claude Max + Gemini Pro quotas.",
  "_mode": "copilot-only",
  "_tier_semantics": {
    "editor": "code-generation-focused model for actual file edits, when primary is better at reasoning than writing code. Falls back to primary if unset.",
    "primary": "role-default agent from routing.phases/routing.roles",
    "weak": "cheap model for mechanical work: commit messages, diff summaries, lint-error interpretation, rubric-scoring. Cost target: 10-30% of primary."
  },
  "overrides": {},
  "providers": {
    "codex": {
      "default": "gpt-5.4",
      "fallback": "gpt-5.4-mini",
      "image": "gpt-image-1",
      "large_context": "gpt-5.4",
      "mini": "gpt-5.4-mini",
      "reasoning": "o3",
      "spark": "gpt-5.4"
    },
    "gemini": {
      "default": "gemini-2.5-flash",
      "fallback": "gemini-2.5-flash",
      "flash": "gemini-2.5-flash",
      "image": "gemini-3-pro-image-preview"
    }
  },
  "routing": {
    "phases": {
      "define": "copilot",
      "deliver": "copilot",
      "develop": "copilot",
      "discover": "copilot-research",
      "research": "copilot-research",
      "review": "copilot",
      "security": "copilot"
    },
    "roles": {
      "builder": "copilot",
      "counter-audit": "copilot",
      "editor": "copilot-sonnet",
      "image": "gemini:image",
      "researcher": "copilot-research",
      "weak": "copilot-haiku"
    }
  },
  "tiers": {
    "budget": {
      "codex": "mini",
      "gemini": "flash"
    },
    "premium": {
      "codex": "default",
      "gemini": "default"
    },
    "standard": {
      "codex": "default",
      "gemini": "default"
    }
  },
  "version": "3.0"
}
