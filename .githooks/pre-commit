#!/usr/bin/env bash
# pre-commit — repo-local git hook.
#
# Activate once with:
#   just hooks-install        (or:  git config core.hooksPath .githooks)
#
# Checks performed (each only runs if its target files are staged):
#   1. Routing presets — verify every config/presets/<mode>.json still matches
#      its source (overlays/_base.json + overlays/<mode>.json). Fails the commit
#      if a generated artifact has been hand-edited.
#
# Add additional checks below as needed.

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
fail=0

# ─── 1. Preset drift ─────────────────────────────────────────────────────────
staged_preset_files=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^config/presets/(([^/]+\.json)|overlays/.+\.json|build\.sh)$' || true)

if [[ -n "$staged_preset_files" ]]; then
    echo "pre-commit: routing-preset files staged — verifying drift..."
    if ! "${REPO_ROOT}/config/presets/build.sh" --verify; then
        cat >&2 <<'EOF'

✗ pre-commit: a committed config/presets/<mode>.json has drifted from its source.

The presets/<mode>.json files are GENERATED ARTIFACTS. Edit the source instead:
  - shared fields → config/presets/overlays/_base.json
  - per-mode fields → config/presets/overlays/<mode>.json

Then rebuild + re-stage:
  just preset-build && git add config/presets/

To bypass this check (only when intentional), commit with:
  git commit --no-verify

EOF
        fail=1
    fi
fi

# ─── 2. Directive + recipe frontmatter ───────────────────────────────────────
staged_memory_md=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^memory/(directives|recipes)/.+\.md$' || true)

if [[ -n "$staged_memory_md" ]]; then
    if ! command -v python3 >/dev/null 2>&1; then
        echo "pre-commit: python3 not found — skipping directive lint" >&2
    else
        echo "pre-commit: directive/recipe frontmatter staged — linting..."
        # Pass the staged paths so we lint exactly what's about to land,
        # not the full memory/ tree (faster + scopes failures to the diff).
        if ! python3 "${REPO_ROOT}/bin/lint-directives.py" $staged_memory_md; then
            cat >&2 <<'EOF'

✗ pre-commit: directive/recipe frontmatter failed validation.

Required fields: name, description, type (one of: knowledge, reference).
Directives (memory/directives/) additionally need non-empty triggers + agents arrays.

See bin/lint-directives.py --help for the full schema.
Bypass intentionally with: git commit --no-verify

EOF
            fail=1
        fi
    fi
fi

exit $fail
